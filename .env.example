# =============================================================
# GymUBB — Variables de entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA subir .env a git (.gitignore ya lo excluye)
# =============================================================

# ---- Base de datos PostgreSQL ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=gym_ubb
DB_USER=gym_ubb_user
DB_PASSWORD=change_this_password

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ---- JWT ----
# Generar con: openssl rand -hex 64
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_chars
JWT_AUDIENCE=gym-ubb

# ---- Servidor ----
PORT=8080
RUNMODE=development   # development | production

# ---- Cloudflare R2 (storage de imágenes) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gym-ubb-assets
R2_PUBLIC_URL=

# ---- CORS (dominio del frontend web, si aplica) ----
ALLOWED_ORIGIN=https://gym.ubiobio.cl

# ── SMTP (verificación de email al registrarse) ───────────────────────────────
#
# Si SMTP_HOST no está definido, el servidor NO falla — imprime el código
# de verificación en los logs del servidor (útil en desarrollo local).
#
# OPCIÓN A — Gmail (correos reales, válido en Docker local con internet)
#   1. Activa 2FA en tu cuenta Google
#   2. Ve a: Google Account → Seguridad → Contraseñas de aplicaciones
#   3. Crea una contraseña para "Correo" → copia el código de 16 caracteres
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tuemail@gmail.com
#   SMTP_PASSWORD=xxxx xxxx xxxx xxxx   ← App Password (sin espacios)
#
# OPCIÓN B — Mailtrap (para pruebas: atrapa los emails, no los entrega)
#   Crea cuenta gratis en https://mailtrap.io → Inbox → SMTP Settings
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=587
#   SMTP_USER=<user de mailtrap>
#   SMTP_PASSWORD=<password de mailtrap>
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
